# Set to "false" to disable Keycloak login entirely (local/dev convenience only)
VITE_KEYCLOAK_ENABLED=true

VITE_KEYCLOAK_URL=https://your-keycloak-host
VITE_KEYCLOAK_REALM=your-realm
VITE_KEYCLOAK_CLIENT_ID=your-client-id

# Public (unauthenticated, read-only) image API
VITE_PUBLIC_API_URL=http://localhost:3000
# Admin/local (authenticated) API
VITE_ADMIN_API_URL=http://localhost:3001
