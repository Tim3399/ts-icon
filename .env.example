# Database
# The relative form below is fine for running the app itself (its own Prisma
# adapter resolves it against prisma/). Running `npx prisma migrate deploy`/
# `db push` directly needs an absolute path instead — see the README's
# Database section for why and a ready-to-use override command.
DATABASE_URL="file:./dev.db"

# TeamSpeak ServerQuery credentials (no defaults - app must fail to start if unset)
TS_HOST=localhost
TS_QUERY_PORT=10011
TS_SERVER_PORT=9987
TS_USERNAME=
TS_USERPASSWORD=

# TeamSpeak ServerQuery transport: 'raw' (classic ServerQuery) or 'ssh'
# (needed for servers, e.g. TeamSpeak 6, that only expose SSH ServerQuery).
# Falls back to 'raw' if unset or unrecognized.
TS_PROTOCOL=raw

# Comma-separated list of allowed CORS origins for the admin/local API
CORS_ORIGINS=http://localhost:5173

# Ports
IMG_WEB_PORT=3000
IMG_API_PORT=3001

# The base URL the public app is actually reachable at -- used to compute
# the banner URL a TeamSpeak channel should be set to point at (the
# banner-url admin feature). No default; required only for that feature.
PUBLIC_BASE_URL=https://your-public-host

# Minimum log severity (verbose|debug|log|warn|error|fatal). Falls back to
# 'debug' outside production, 'log' in production, if unset or unrecognized.
LOG_LEVEL=debug

# Keycloak / OIDC — backend validates JWTs locally via JWKS, no client secret needed
OIDC_ISSUER_URL=https://your-keycloak-host/realms/your-realm
OIDC_AUDIENCE=your-client-id
OIDC_ADMIN_ROLE=ts-icon-admin
OIDC_EDITOR_ROLE=ts-icon-editor

# Disables backend authentication entirely on the `local` (admin) app -- a
# loopback-only escape hatch for running the whole stack without a Keycloak
# instance at hand (pair with the frontend's VITE_KEYCLOAK_ENABLED=false, see
# webapp-banner-tool/.env.example). Refuses to start if NODE_ENV=production,
# and every request must still come from a loopback/private address even
# when enabled (see src/auth/no-auth.guard.ts) -- but nothing else stops you
# from setting this on a host that IS reachable from a real network. NEVER
# do that.
#
# Local-npm only: Docker Compose's image always sets NODE_ENV=production
# (see Dockerfile), so AUTH_DISABLED=true there will always fail to start.
AUTH_DISABLED=false
