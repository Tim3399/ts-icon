# Database
DATABASE_URL="file:./dev.db"

# TeamSpeak ServerQuery credentials (no defaults - app must fail to start if unset)
TS_HOST=localhost
TS_QUERY_PORT=10011
TS_SERVER_PORT=9987
TS_USERNAME=
TS_USERPASSWORD=

# Comma-separated list of allowed CORS origins for the admin/local API
CORS_ORIGINS=http://localhost:5173

# Ports
IMG_WEB_PORT=3000
IMG_API_PORT=3001

# Keycloak / OIDC — backend validates JWTs locally via JWKS, no client secret needed
OIDC_ISSUER_URL=https://your-keycloak-host/realms/your-realm
OIDC_AUDIENCE=your-client-id
OIDC_ADMIN_ROLE=ts-icon-admin
OIDC_EDITOR_ROLE=ts-icon-editor
